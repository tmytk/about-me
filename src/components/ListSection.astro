---
const {
    title = "",
    items = [],
    titleHref = "",
    emptyMessage = "No entries.",
} = Astro.props;
const hasItems = items.length > 0;
---

<section class="grid gap-4" data-section>
    {title ? (
        <header>
            <p class="m-0 mb-1.5 text-xs font-normal uppercase tracking-[0.08em] text-blue-deep">Archive</p>
            <h2 class="m-0 text-[19px] font-normal text-blue-deep">
                {titleHref ? <a class="text-inherit no-underline hover:text-blue" href={titleHref}>{title}</a> : title}
            </h2>
        </header>
    ) : null}
    <div class="grid gap-4">
        {hasItems
            ? items.map((item) => (
                  item.href ? (
                      <a class="flex items-start justify-between gap-[18px] border-b border-line py-3.5 text-ink no-underline hover:border-blue hover:text-blue-deep" href={item.href} data-title={item.title} target={item.external ? "_blank" : undefined} rel={item.external ? "noopener noreferrer" : undefined}>
                          <div>
                              <h3 class="m-0 text-[17px] font-normal">{item.title}</h3>
                              {item.desc ? <p class="m-0 mt-1.5 text-sm text-muted">{item.desc}</p> : null}
                          </div>
                          {item.date ? <time class="shrink-0 text-[13px] text-muted">{item.date}</time> : null}
                      </a>
                  ) : (
                      <article class="flex items-start justify-between gap-[18px] border-b border-line py-3.5 text-ink" data-title={item.title}>
                          <div>
                              <h3 class="m-0 text-[17px] font-normal">{item.title}</h3>
                              {item.desc ? <p class="m-0 mt-1.5 text-sm text-muted">{item.desc}</p> : null}
                          </div>
                          {item.date ? <time class="shrink-0 text-[13px] text-muted">{item.date}</time> : null}
                      </article>
                  )
              ))
            : null}
        <p class="m-0 py-3.5 text-muted" data-empty hidden={hasItems}>{emptyMessage}</p>
    </div>
</section>
