---
import { SITE_DOMAIN } from "../lib/constant";
import { getSectionLabel, SECTIONS } from "../lib/sections";

const { narrow = false } = Astro.props;
const currentPath = Astro.url.pathname;
const sectionNavItems = SECTIONS.map((key) => ({
  href: `/${key}`,
  label: getSectionLabel(key),
  active: currentPath === `/${key}` || currentPath.startsWith(`/${key}/`),
}));
const navItems = [
  {
    href: "/career",
    label: "Career",
    active: currentPath === "/career" || currentPath.startsWith("/career/"),
  },
  ...sectionNavItems,
];
---

<div
  class="mx-auto w-[min(1120px,calc(100%-32px))] max-[700px]:w-[min(100%-22px,1120px)]"
>
  <header class="bg-paper" aria-label="Site header">
    <div
      class="flex items-center justify-between gap-[18px] border-b border-line pt-3 pb-3 max-[700px]:flex-wrap max-[700px]:gap-2 max-[700px]:pt-3"
    >
      <a
        class="inline-flex min-w-0 items-center text-ink no-underline"
        href="/"
        aria-label={`${SITE_DOMAIN} home`}
      >
        <span
          class="text-sm tracking-[0.04em] text-ink-soft max-[700px]:overflow-hidden max-[700px]:text-ellipsis max-[700px]:whitespace-nowrap"
          >{SITE_DOMAIN}</span
        >
      </a>
      <nav
        class="inline-flex items-center gap-1 pr-0.5 max-[700px]:grid max-[700px]:w-full max-[700px]:grid-cols-4 max-[700px]:p-0"
        aria-label="Primary navigation"
      >
        {
          navItems.map((item) => (
            <a
              class:list={[
                "inline-flex min-h-[34px] items-center rounded-lg px-2 text-sm text-muted no-underline transition-colors hover:text-blue-deep max-[700px]:justify-center max-[700px]:px-1.5",
                item.active && "text-blue-deep",
              ]}
              href={item.href}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>
  </header>
  <main
    class:list={[
      "grid gap-[42px] px-4 pt-[22px] pb-[72px] max-[700px]:gap-[30px] max-[700px]:px-3 max-[700px]:pt-3",
      narrow && "mx-auto max-w-[820px]",
    ]}
  >
    <slot />
  </main>
</div>
