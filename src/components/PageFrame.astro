---
import { getCollection } from "astro:content";
import { SITE_DOMAIN } from "../lib/constant";
import { getSectionLabel, SECTIONS } from "../lib/sections";
import type { SectionKey } from "../lib/sections";

interface Props {
  narrow?: boolean;
}

type CategoryItem = {
  section: SectionKey;
  href: string;
  label: string;
  count: number;
  active: boolean;
};

const { narrow = false }: Props = Astro.props;
const currentPath = Astro.url.pathname;
type NavItem = {
  href: string;
  label: string;
  active: boolean;
};
const navItems: NavItem[] = [
  {
    href: "/career",
    label: "Career",
    active: currentPath === "/career" || currentPath.startsWith("/career/"),
  },
];

const categoryItems: CategoryItem[] = await Promise.all(
  SECTIONS.map(async (section) => {
    const entries = await getCollection(section);
    return {
      section,
      href: `/${section}`,
      label: getSectionLabel(section),
      count: entries.length,
      active: currentPath === `/${section}` || currentPath.startsWith(`/${section}/`),
    };
  }),
);
---

<div
  class="mx-auto w-[min(1120px,calc(100%-32px))] max-[700px]:w-[min(100%-22px,1120px)]"
>
  <header class="bg-paper" aria-label="Site header">
    <div
      class="flex items-center justify-between gap-4.5 border-b border-line pt-3 pb-3 max-[700px]:gap-2 max-[700px]:pt-3"
    >
      <a
        class="inline-flex min-w-0 items-center text-ink no-underline"
        href="/"
        aria-label={`${SITE_DOMAIN} home`}
      >
        <span
          class="text-sm tracking-[0.04em] text-ink-soft max-[700px]:overflow-hidden max-[700px]:text-ellipsis max-[700px]:whitespace-nowrap"
          >{SITE_DOMAIN}</span
        >
      </a>
      <nav
        class="inline-flex items-center gap-1 pr-0.5"
        aria-label="Primary navigation"
      >
        {
          navItems.map((item) => (
            <a
              class:list={[
                "inline-flex min-h-8.5 items-center rounded-lg px-2 text-sm text-muted no-underline transition-colors hover:text-blue-deep max-[700px]:px-1.5",
                item.active && "text-blue-deep",
              ]}
              href={item.href}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>
  </header>
  <main
    class:list={[
      "grid gap-10.5 px-4 pt-5.5 pb-18 max-[700px]:gap-7.5 max-[700px]:px-3 max-[700px]:pt-3",
      narrow && "mx-auto max-w-205",
    ]}
  >
    <nav class="grid grid-cols-3 gap-3" aria-label="Memo categories">
      {
        categoryItems.map((item) => (
          <a
            class="grid gap-1.5 py-3.5 text-inherit no-underline hover:[&_span]:text-blue"
            href={item.href}
          >
            <span
              class:list={[
                "text-lg font-normal leading-[1.3] text-blue-deep",
                item.active && "text-blue",
              ]}
            >
              {item.label}
            </span>
            <small class="text-[13px] font-normal text-muted">
              {item.count} md
            </small>
          </a>
        ))
      }
    </nav>
    <slot />
  </main>
</div>
