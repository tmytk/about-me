---
const { name = "", githubUser = "", affiliation = {}, bio = "" } = Astro.props;
---

<section class="bg-transparent px-0 py-[clamp(28px,5vw,52px)]">
    <p class="m-0 mb-3 text-xs font-normal uppercase tracking-[0.08em] text-blue-deep">Portfolio</p>
    <h1 class="m-0 text-[clamp(30px,4vw,36px)] font-normal leading-[1.2] tracking-[-0.02em]">
        <a class="text-ink no-underline hover:text-blue" href={`https://github.com/${githubUser}`} target="_blank" rel="noopener noreferrer">
            {name}
        </a>
    </h1>
    <p class="mt-[18px] mb-0 flex flex-wrap gap-2 text-muted">
        {affiliation.label}
        {affiliation.companyUrl ? (
            <>
                <span>/</span>
                <a class="text-blue-deep no-underline hover:text-blue" href={affiliation.companyUrl} target="_blank" rel="noopener noreferrer">
                    {affiliation.companyName}
                </a>
            </>
        ) : null}
        {affiliation.suffix ? <span>{affiliation.suffix}</span> : null}
    </p>
    <p class="mt-5 mb-0 max-w-[680px] text-base leading-[1.85] text-ink-soft">{bio}</p>
</section>
