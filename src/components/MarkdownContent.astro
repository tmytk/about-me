<script is:inline>
    const copyText = async (text) => {
        if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(text);
            return;
        }

        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.opacity = "0";
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand("copy");
        textarea.remove();
    };

    const setupCodeCopy = () => {
        document.querySelectorAll(".markdown pre").forEach((pre) => {
            if (pre.parentElement?.classList.contains("code-block")) return;

            const wrapper = document.createElement("div");
            wrapper.className = "code-block group relative my-6";
            pre.parentNode?.insertBefore(wrapper, pre);
            wrapper.appendChild(pre);
            pre.classList.add("!m-0");

            const button = document.createElement("button");
            button.type = "button";
            button.className = "pointer-events-none absolute right-3 top-2 border-0 bg-transparent p-0 font-mono text-[11px] leading-none text-[#f1f0ea]/45 opacity-0 transition-colors transition-opacity hover:text-[#f1f0ea] group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:opacity-100";
            button.textContent = "copy";
            button.setAttribute("aria-label", "コードをコピー");
            wrapper.appendChild(button);

            button.addEventListener("click", async () => {
                const code = pre.querySelector("code")?.innerText ?? pre.innerText;
                try {
                    await copyText(code);
                    button.textContent = "copied";
                    window.setTimeout(() => {
                        button.textContent = "copy";
                    }, 1200);
                } catch {
                    button.textContent = "failed";
                    window.setTimeout(() => {
                        button.textContent = "copy";
                    }, 1200);
                }
            });
        });
    };

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", setupCodeCopy);
    } else {
        setupCodeCopy();
    }
</script>
