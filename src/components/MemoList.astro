---
const {
    items = [],
    emptyMessage = "No entries.",
    title = "",
    titleHref = "",
    showDesc = true,
} = Astro.props;
const hasItems = items.length > 0;
---

<section class="grid gap-4" data-section>
    {title ? (
        <header>
            <h2 class="m-0 text-lg font-normal leading-[1.3] text-blue-deep">
                {titleHref ? <a class="text-inherit no-underline hover:text-blue" href={titleHref}>{title}</a> : title}
            </h2>
        </header>
    ) : null}
    <div class="grid">
        {hasItems
            ? items.map((item) => (
                  <a class="grid grid-cols-[112px_minmax(0,1fr)] gap-[18px] border-b border-line py-3.5 text-ink no-underline hover:[&_h3]:text-blue max-sm:grid-cols-1 max-sm:gap-1" href={item.href} data-title={item.title}>
                      <time class="text-[13px] text-muted">{item.date}</time>
                      <div>
                          <h3 class="m-0 text-base font-normal leading-[1.45] text-ink">{item.title}</h3>
                          {showDesc && item.desc ? <p class="m-0 mt-1 text-sm leading-[1.65] text-muted">{item.desc}</p> : null}
                      </div>
                  </a>
              ))
            : null}
        <p class="m-0 py-3.5 text-muted hidden:[display:none]" data-empty hidden={hasItems}>{emptyMessage}</p>
    </div>
</section>
