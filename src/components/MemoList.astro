---
import type { MemoItem } from "../lib/memos";

interface Props {
  items?: MemoItem[];
  emptyMessage?: string;
  title?: string;
  titleHref?: string;
  showDesc?: boolean;
}

const {
  items = [],
  emptyMessage = "No entries.",
  title = "",
  titleHref = "",
  showDesc = true,
}: Props = Astro.props;
const hasItems = items.length > 0;
---

<section class="grid gap-4">
  {
    title ? (
      <header>
        <h2 class="m-0 text-lg font-normal leading-[1.3] text-blue-deep">
          {titleHref ? (
            <a
              class="text-inherit no-underline hover:text-blue"
              href={titleHref}
            >
              {title}
            </a>
          ) : (
            title
          )}
        </h2>
      </header>
    ) : null
  }
  <div class="grid">
    {
      hasItems
        ? items.map((item) => (
            <a
              class="grid grid-cols-[112px_minmax(0,1fr)] gap-4.5 border-b border-line py-3.5 text-ink no-underline hover:[&_h3]:text-blue max-sm:grid-cols-1 max-sm:gap-1"
              href={item.href}
            >
              <time class="text-[13px] text-muted">{item.date}</time>
              <div>
                <h3 class="m-0 text-base font-normal leading-[1.45] text-ink">
                  {item.title}
                </h3>
                {showDesc && item.desc ? (
                  <p class="m-0 mt-1 text-sm leading-[1.65] text-muted">
                    {item.desc}
                  </p>
                ) : null}
              </div>
            </a>
          ))
        : null
    }
    <p
      class="m-0 py-3.5 text-muted hidden:[display:none]"
      hidden={hasItems}
    >
      {emptyMessage}
    </p>
  </div>
</section>
