---
interface Props {
  inputId?: string;
  scope?: string;
}

const { inputId = "#section-search", scope = "[data-section]" }: Props = Astro.props;
---

<script define:vars={{ inputId, scope }}>
    const input = document.querySelector(inputId);
    const sections = document.querySelectorAll(scope);

    const filterItems = () => {
        if (!input) return;
        const query = input.value.trim().toLowerCase();

        sections.forEach((section) => {
            const rows = Array.from(section.querySelectorAll("[data-title]"));
            let visibleCount = 0;

            rows.forEach((row) => {
                const title = row.getAttribute("data-title") || "";
                const match = title.toLowerCase().includes(query);
                row.hidden = !match;
                if (match) visibleCount += 1;
            });

            const empty = section.querySelector("[data-empty]");
            if (empty) {
                empty.hidden = visibleCount !== 0;
            }
        });
    };

    if (input) {
        input.addEventListener("input", filterItems);
    }
</script>
