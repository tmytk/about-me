---
interface Props {
  id?: string;
  placeholder?: string;
  label?: string;
}

const {
    id = "title-search",
    placeholder = "Search titles",
    label = "",
}: Props = Astro.props;
import { Search } from "@lucide/astro";
---

<label class="grid w-[min(100%,420px)] gap-2">
    {label ? <span class="text-xs font-normal uppercase tracking-[0.08em] text-muted">{label}</span> : null}
    <div class="flex min-h-11 items-center gap-2.5 border-b border-line bg-transparent text-muted transition-colors focus-within:border-blue">
        <Search class="h-[18px] w-[18px] shrink-0 stroke-current" size={18} stroke-width={1.8} aria-hidden="true" />
        <input class="min-w-0 flex-1 border-0 bg-transparent p-0 text-[15px] leading-[1.4] text-ink placeholder:text-[#8d99ac] focus:outline-none" id={id} type="search" placeholder={placeholder} />
    </div>
</label>
