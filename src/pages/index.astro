---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageFrame from "../components/PageFrame.astro";
import { SITE_DOMAIN } from "../lib/constant";
import { getSectionLabel, SECTIONS } from "../lib/sections";
import type { SectionKey } from "../lib/sections";

type MemoEntry = {
  id: string;
  data: {
    title: string;
    date: Date;
  };
};

type MemoIndexItem = {
  section: SectionKey;
  entry: MemoEntry;
  href: string;
  label: string;
};

const formatDate = (date: Date | undefined) =>
  date instanceof Date
    ? date.toISOString().slice(0, 10).replaceAll("-", ".")
    : "";

const collections = await Promise.all(
  SECTIONS.map(async (section) => ({
    section,
    entries: await getCollection(section),
  })),
);

const memoItems: MemoIndexItem[] = collections
  .flatMap(({ section, entries }) =>
    entries.map((entry) => ({
      section,
      entry: entry as CollectionEntry<typeof section> & MemoEntry,
      href: `/${section}/${entry.id}`,
      label: getSectionLabel(section),
    })),
  )
  .sort(
    (a, b) =>
      (b.entry.data.date?.getTime?.() ?? 0) -
      (a.entry.data.date?.getTime?.() ?? 0),
  );
---

<BaseLayout
  title={`Memo | ${SITE_DOMAIN}`}
  description="技術メモ、日々のメモ、音楽ログの一覧。"
>
  <PageFrame narrow>
    <section class="grid gap-6 p-0" aria-label="Memo index">
      <section class="grid" aria-label="All memos">
        {
          memoItems.map(({ entry, href, label }) => (
            <a
              class="grid grid-cols-[112px_minmax(0,1fr)_84px] items-baseline gap-4 border-b border-line py-4 text-inherit no-underline hover:[&_strong]:text-blue max-[720px]:grid-cols-[auto_1fr] max-[720px]:gap-x-3 max-[720px]:gap-y-1"
              href={href}
            >
              <time
                class="text-[13px] font-normal text-muted max-[720px]:col-start-1 max-[720px]:row-start-1"
                datetime={entry.data.date.toISOString()}
              >
                {formatDate(entry.data.date)}
              </time>
              <strong class="overflow-hidden text-ellipsis whitespace-nowrap text-base font-normal text-ink max-[720px]:col-span-2 max-[720px]:row-start-2 max-[720px]:whitespace-normal">
                {entry.data.title}
              </strong>
              <span class="text-[13px] font-normal text-muted max-[720px]:col-start-2 max-[720px]:row-start-1">
                {label}
              </span>
            </a>
          ))
        }
      </section>
    </section>
  </PageFrame>
</BaseLayout>
