---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import MarkdownContent from "../../components/MarkdownContent.astro";
import PageFrame from "../../components/PageFrame.astro";
import { SITE_DOMAIN } from "../../lib/constant";
import { getSectionLabel, SECTIONS } from "../../lib/sections";

export const getStaticPaths = async () => {
  const paths = [];

  for (const section of SECTIONS) {
    const entries = await getCollection(section);
    for (const entry of entries) {
      paths.push({ params: { section, slug: entry.id }, props: { entry } });
    }
  }

  return paths;
};

const formatDate = (date: Date | undefined) =>
  date instanceof Date
    ? date.toISOString().slice(0, 10).replaceAll("-", ".")
    : "";

const { entry } = Astro.props;
const section = entry.collection;
const sectionLabel = getSectionLabel(section);
const { Content } = await render(entry);
const crumbs = [
  { label: "Home", href: "/" },
  { label: sectionLabel, href: `/${section}` },
  { label: entry.data.title },
];
---

<BaseLayout
  title={`${entry.data.title} | ${SITE_DOMAIN}`}
  description={entry.data.title}
>
  <PageFrame narrow>
    <Breadcrumbs items={crumbs} />
    <article class="grid gap-6.5">
      <header class="grid gap-2.5 border-b border-line pb-6">
        <p
          class="m-0 text-xs font-normal uppercase tracking-[0.08em] text-blue-deep"
        >
          {sectionLabel}
        </p>
        <h1
          class="m-0 text-[clamp(26px,4vw,34px)] font-normal leading-tight tracking-[-0.02em] text-blue-deep"
        >
          {entry.data.title}
        </h1>
        <time
          class="text-[15px] text-muted"
          datetime={entry.data.date.toISOString()}
          >{formatDate(entry.data.date)}</time
        >
      </header>
      <MarkdownContent>
        <Content />
      </MarkdownContent>
    </article>
  </PageFrame>
</BaseLayout>
